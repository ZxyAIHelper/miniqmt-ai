{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "stop": {
      "type": "boolean",
      "description": "True when further strategy search is unlikely to be useful."
    },
    "reason": {
      "type": "string",
      "description": "Concise explanation for stopping or continuing."
    },
    "diagnosis": {
      "type": "string",
      "description": "History-based quantitative diagnosis of what worked, failed, and why."
    },
    "avoid": {
      "type": "object",
      "additionalProperties": false,
      "description": "Factors or parameter regions the agent recommends avoiding based on historical results.",
      "properties": {
        "factors": {
          "type": "array",
          "items": {"type": "string"}
        },
        "parameter_regions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reason": {
          "type": "string"
        }
      },
      "required": ["factors", "parameter_regions", "reason"]
    },
    "focus": {
      "type": "object",
      "additionalProperties": false,
      "description": "Factors, parameter regions, or hypotheses the agent recommends focusing on next.",
      "properties": {
        "factors": {
          "type": "array",
          "items": {"type": "string"}
        },
        "parameter_regions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "hypotheses": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reason": {
          "type": "string"
        }
      },
      "required": ["factors", "parameter_regions", "hypotheses", "reason"]
    },
    "review_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "When the agent wants to inspect the next round instead of waiting for every planned combination.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["full_round", "after_n_trials"]
        },
        "min_completed_trials": {
          "type": "integer",
          "minimum": 0
        },
        "review_every_trials": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string"
        }
      },
      "required": ["mode", "min_completed_trials", "review_every_trials", "reason"]
    },
    "strategies": {
      "type": "array",
      "description": "New strategy candidates to try next. Empty when stop is true.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "weights": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "factor": {
                  "type": "string"
                },
                "weight": {
                  "type": "number"
                }
              },
              "required": ["factor", "weight"]
            }
          },
          "parameter_grid": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "top": {
                "type": "array",
                "items": {"type": "integer", "enum": [3, 5, 8]}
              },
              "lookback": {
                "type": "array",
                "items": {"type": "integer", "enum": [40, 60, 90]}
              },
              "rebalance_days": {
                "type": "array",
                "items": {"type": "integer", "enum": [10, 20, 40]}
              }
            },
            "required": ["top", "lookback", "rebalance_days"]
          },
          "research_thesis": {
            "type": "string",
            "description": "Why this factor mix and parameter grid are worth testing."
          }
        },
        "required": ["name", "description", "weights", "parameter_grid", "research_thesis"]
      }
    }
  },
  "required": ["stop", "reason", "diagnosis", "avoid", "focus", "review_policy", "strategies"]
}
